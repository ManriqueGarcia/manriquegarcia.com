---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Hoteles y Alojamiento">
	<main class="container">
		<h1>Hoteles y Alojamiento</h1>
		<p class="page-intro">Gijón dispone de una gran variedad de hoteles. Aquí hemos resumido los más conocidos.</p>
		<div class="section-note"><p>Es importante reservar con tiempo.</p></div>

		<h2>Hoteles en Gijón</h2>
		<div class="card-grid">
			<div class="card">
				<h3>Hotel Hernán Cortés</h3>
				<p class="address">Fernández Vallín 5, Gijón</p>
				<p class="phone">Tel: 985 346 000</p>
				<p class="description">Centro de Gijón, a 10 min de playa San Lorenzo.</p>
				<p><span class="tag">Céntrico</span> <span class="tag">WiFi gratuita</span></p>
				<p><a href="https://hotelhernancortes.es" rel="noopener noreferrer">hotelhernancortes.es</a></p>
			</div>
			<div class="card">
				<h3>Hotel Begoña Park</h3>
				<p class="address">Ctra. de la Providencia 566, Gijón</p>
				<p class="phone">Tel: 985 133 909</p>
				<p class="description">Cerca del Rinconín, playa San Lorenzo.</p>
				<p><span class="tag">Parking</span> <span class="tag">WiFi</span></p>
				<p><a href="https://hotelesbegona.com" rel="noopener noreferrer">hotelesbegona.com</a></p>
			</div>
			<div class="card">
				<h3>Hotel ABBA</h3>
				<p class="address">Doctor Fleming 37, Gijón</p>
				<p class="phone">Tel: 985 000 000</p>
				<p class="description">Al lado de playa San Lorenzo y Parque Isabel la Católica.</p>
				<p><a href="https://abbagijonhotel.com" rel="noopener noreferrer">abbagijonhotel.com</a></p>
			</div>
			<div class="card">
				<h3>Parador Nacional Molino Viejo</h3>
				<p class="address">Parque Isabel la Católica s/n, Gijón</p>
				<p class="phone">Tel: 985 370 511</p>
				<p class="description">Antiguo molino centenario, vistas al parque, fabada estrella.</p>
				<p><span class="tag">Parking</span> <span class="tag">WiFi</span></p>
				<p><a href="https://parador.es" rel="noopener noreferrer">parador.es</a></p>
			</div>
			<div class="card">
				<h3>Hotel TRYP Rey Pelayo</h3>
				<p class="address">V. Torcuato Fdez. Miranda 26, Gijón</p>
				<p class="phone">Tel: 985 199 800</p>
				<p class="description">Cerca de playa, Molinón, Plaza de Toros. Frente al Palacio de Congresos.</p>
			</div>
			<div class="card">
				<h3>Hotel AC Gijón</h3>
				<p class="address">Avda. de Oviedo 15, Gijón</p>
				<p class="phone">Tel: 985 990 500</p>
				<p class="description">Moderno, zona residencial, 10 min del centro.</p>
				<p><a href="https://ac-hotels.com" rel="noopener noreferrer">ac-hotels.com</a></p>
			</div>
			<div class="card">
				<h3>Hotel Villa de Gijón</h3>
				<p class="address">C/ San Juan de Vallés 3, Gijón</p>
				<p class="phone">Tel: 985 141 824</p>
				<p><a href="https://hotelvilladegijon.com" rel="noopener noreferrer">hotelvilladegijon.com</a></p>
			</div>
			<div class="card">
				<h3>Hotel Begoña Centro</h3>
				<p class="address">Avda. de la Costa 44, Gijón</p>
				<p class="phone">Tel: 985 147 211</p>
				<p class="description">Centro, zona comercial, cerca de estaciones y playa.</p>
				<p><span class="tag">Céntrico</span></p>
				<p><a href="https://hotelesbegona.com" rel="noopener noreferrer">hotelesbegona.com</a></p>
			</div>
			<div class="card">
				<h3>Hotel Blue Santa Rosa</h3>
				<p class="address">Santa Rosa 4, Gijón</p>
				<p class="phone">Tel: 985 091 919</p>
				<p class="description">Centro peatonal, a 50m de playa, puerto deportivo, Plaza Mayor.</p>
				<p><span class="tag">Céntrico</span> <span class="tag">WiFi</span></p>
				<p><a href="https://bluehoteles.es" rel="noopener noreferrer">bluehoteles.es</a></p>
			</div>
			<div class="card">
				<h3>Hotel Blue Marqués de San Esteban</h3>
				<p class="address">Avda Marqués de San Esteban 11, Gijón</p>
				<p class="phone">Tel: 985 090 929</p>
				<p class="description">Edificio clásico restaurado, junto al Puerto Deportivo. 27 habitaciones.</p>
			</div>
			<div class="card">
				<h3>Apartamentos San Esteban</h3>
				<p class="address">C/ Marqués de San Esteban 11, Gijón</p>
				<p class="phone">Tel: 985 09 09 29</p>
				<p class="description">Estudios y apartamentos de 1-2 habitaciones, cocina completa.</p>
				<p><span class="tag">WiFi</span></p>
				<p><a href="https://bluehoteles.es" rel="noopener noreferrer">bluehoteles.es</a></p>
			</div>
			<div class="card">
				<h3>Hotel León</h3>
				<p class="address">Avda. de la Costa 45, Gijón</p>
				<p class="phone">Tel: 985 37 01 11</p>
				<p class="description">Más de 30 años de trayectoria.</p>
				<p><a href="https://hotel-leon.com" rel="noopener noreferrer">hotel-leon.com</a></p>
			</div>
			<div class="card">
				<h3>Hotel Celuisma Pathos</h3>
				<p class="address">Santa Elena 6, Gijón</p>
				<p class="phone">Tel: 985 176 400</p>
				<p class="description">Centro, decoración temática con personajes del siglo XX.</p>
				<p><span class="tag">Céntrico</span></p>
			</div>
			<div class="card">
				<h3>Hotel Castilla</h3>
				<p class="address">C/ Corrida 50, Gijón</p>
				<p class="phone">Tel: 985 346 200</p>
				<p class="description">Clásico, centro, 2 estrellas.</p>
				<p><span class="tag">Céntrico</span></p>
			</div>
			<div class="card">
				<h3>Hotel La Polar</h3>
				<p class="address">Avda Juan Carlos I, 20, Gijón</p>
				<p class="phone">Tel: 984 29 64 03</p>
				<p class="description">Centro histórico junto al mar, temática marina, balcón en todas las habitaciones.</p>
			</div>
			<div class="card">
				<h3>Hotel Miramar</h3>
				<p class="address">C/ Santa Lucía 9, Gijón</p>
				<p class="phone">Tel: 985 351 008</p>
				<p class="description">Centro, edificio histórico de 1926, a metros de playa y puerto.</p>
			</div>
			<div class="card">
				<h3>Hotel Arena</h3>
				<p class="address">C/ Doctor Aquilino Hurlé 31, Gijón</p>
				<p class="phone">Tel: 985 339 700</p>
				<p class="description">A 100m de playa San Lorenzo, Barrio la Arena.</p>
				<p><a href="https://hotelarena.es" rel="noopener noreferrer">hotelarena.es</a></p>
			</div>
			<div class="card">
				<h3>Hotel Alcomar</h3>
				<p class="address">C/ Cabrales 24, Gijón</p>
				<p class="phone">Tel: 985 357 011</p>
				<p class="description">Vistas al paseo marítimo, gestión familiar, recepción 24h.</p>
				<p><span class="tag">WiFi</span></p>
			</div>
			<div class="card">
				<h3>Casona de Cefontes</h3>
				<p class="address">Camino de la Carbayera 564, Castiello de Bernueces, Gijón</p>
				<p class="phone">Tel: 606 163 410</p>
				<p class="description">Rural, rodeado de zonas verdes, 5 km de la playa.</p>
				<p><span class="tag">Parking</span></p>
			</div>
			<div class="card">
				<h3>Hotel Doña María</h3>
				<p class="address">Ctra Carbonera 28, Gijón</p>
				<p class="phone">Tel: 985 14 01 17</p>
				<p class="description">Restaurante propio.</p>
			</div>
			<div class="card">
				<h3>Camping Deva</h3>
				<p class="address">Camín de la Pasadiella 85, Gijón</p>
				<p class="phone">Tel: 985 13 38 48</p>
				<p class="description">1ª categoría, 4 km del centro. Bungalows 4-5 plazas, cabañas 6 plazas, chalets 10 plazas.</p>
				<p><span class="tag warm">Camping</span></p>
			</div>
		</div>
	</main>
</BaseLayout>
