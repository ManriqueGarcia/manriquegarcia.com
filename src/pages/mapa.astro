---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Mapa">
	<main class="container">
		<h1>Mapa de Asturias</h1>
		<p class="page-intro">
			Todos los restaurantes, sidrerías, hoteles, bares y lugares que visitar de la guía, ubicados en el mapa.
			Pulsa en cada marcador para ver los detalles.
		</p>

		<div class="map-legend">
			<span class="legend-item"><span class="legend-icon" style="background:#b8960f;">🏆</span> Sublime</span>
			<span class="legend-item"><span class="legend-icon" style="background:#1a6b3c;">🍾</span> Sidrería / Restaurante</span>
			<span class="legend-item"><span class="legend-icon" style="background:#b45309;">🍴</span> Restaurante</span>
			<span class="legend-item"><span class="legend-icon" style="background:#7c3aed;">🏨</span> Hotel</span>
			<span class="legend-item"><span class="legend-icon" style="background:#0369a1;">📍</span> Qué visitar</span>
			<span class="legend-item"><span class="legend-icon" style="background:#be185d;">🍺</span> Bares / Copas</span>
		</div>

		<div id="map"></div>
	</main>
</BaseLayout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
	integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<style>
	#map {
		width: 100%;
		height: 70vh;
		min-height: 420px;
		border-radius: 12px;
		border: 1px solid var(--color-border);
		box-shadow: 0 2px 12px rgba(0,0,0,0.08);
		z-index: 0;
	}

	.map-legend {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1.5rem;
		margin-bottom: 1rem;
		font-size: 0.88rem;
	}

	.legend-item {
		display: flex;
		align-items: center;
		gap: 0.35rem;
	}

	.legend-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		font-size: 14px;
		color: white;
		flex-shrink: 0;
	}
</style>

<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
	integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<script is:inline>
document.addEventListener('DOMContentLoaded', function () {
	var map = L.map('map').setView([43.48, -5.55], 10);

	L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
		maxZoom: 18,
		attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
	}).addTo(map);

	function icon(emoji, bg) {
		return L.divIcon({
			html: '<div style="background:' + bg + ';width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;border:2px solid white;box-shadow:0 2px 6px rgba(0,0,0,0.3);">' + emoji + '</div>',
			iconSize: [32, 32],
			iconAnchor: [16, 16],
			popupAnchor: [0, -18],
			className: ''
		});
	}

	var iconSidreria  = icon('🍾', '#1a6b3c');
	var iconRestaurant = icon('🍴', '#b45309');
	var iconHotel     = icon('🏨', '#7c3aed');
	var iconVisit     = icon('📍', '#0369a1');
	var iconBar       = icon('🍺', '#be185d');

	var iconSublime = icon('🏆', '#b8960f');

	var places = [
		// === SIDRERÍAS / RESTAURANTES (Gijón) ===
		{ lat: 43.5082, lng: -5.6335, name: 'Sidrería Trabanco', info: 'Camín de la Sidra, Lavandera · Tel: 985 16 72 86<br>LA sidrería. Categoría Sublime. Producen su propia sidra y la comida ye espectacular.', url: 'https://www.trabanco.es', icon: iconSublime },
		{ lat: 43.5329, lng: -5.6605, name: 'El Sauco', info: 'C/ Valencia 20 · Tel: 985 39 83 30<br>Sidras, pinchos, menú y carta. ★★★★★', url: 'http://www.elsauco.com', icon: iconSidreria },
		{ lat: 43.5327, lng: -5.6588, name: 'Parrilla Antonio', info: 'Roncal 1 · Tel: 985 154 973<br>Pinchos y parrilla. ★★★★', icon: iconSidreria },
		{ lat: 43.5330, lng: -5.6575, name: 'Sidrería Nava', info: 'C/ de la Serena 1 · Tel: 985 380 447<br>Sidra de calidad y buen menú. ★★★★', icon: iconSidreria },
		{ lat: 43.5456, lng: -5.6630, name: 'La Galana', info: 'Plaza Mayor 10 · Tel: 985 17 24 29<br>Céntrico, sidra y buena comida. ★★★★', icon: iconSidreria },
		{ lat: 43.5374, lng: -5.6655, name: 'La Chalana', info: 'C/ San José 31 · Tel: 98 516 48 27<br>Especialidad en marisco. ★★★★', url: 'http://www.lachalana.com', icon: iconRestaurant },
		{ lat: 43.5256, lng: -5.6427, name: 'El Celorio', info: 'C/ Juliana Domingo 6 · Tel: 984 393 962<br>El cachopo asturiano. ★★★★', icon: iconRestaurant },
		{ lat: 43.5370, lng: -5.6580, name: 'Casa Ferino', info: 'Ctra. de la Carbonera · Tel: 985 380 471<br>Especialidad en callos. ★★★★', url: 'http://www.casaferino.com', icon: iconSidreria },
		{ lat: 43.3952, lng: -5.6516, name: 'El Llagar del Quesu', info: 'Bobes 2, Siero · Tel: 98 579 28 94<br>Parrilla argentina, muy acogedor. ★★★★★', icon: iconRestaurant },
		{ lat: 43.5440, lng: -5.6657, name: 'Sidrería El Globo', info: 'C/ San Bernardo 13 · Tel: 985 17 22 47<br>Comida típica asturiana. ★★★', url: 'http://www.sidreriaelglobo.es', icon: iconSidreria },
		{ lat: 43.5418, lng: -5.6553, name: 'Sidrería La Costa', info: 'Av. Costa 32<br>Especialidad en caza. ★★★★', icon: iconSidreria },
		{ lat: 43.5420, lng: -5.6548, name: 'Tino El Roxu', info: 'Av. de la Costa 30 · Tel: 985 141 792<br>Cocina tradicional asturiana. ★★★★', icon: iconSidreria },
		{ lat: 43.5382, lng: -5.6509, name: 'Sidrería Cabranes', info: 'Av. Pablo Iglesias 23 · Tel: 98 513 1487<br>Rabo de toro. ★★★★', icon: iconSidreria },
		{ lat: 43.5332, lng: -5.6592, name: 'Barrio de la Sidra', info: 'Zona del Llano: Parrilla Antonio I, Casa César, La Esquina, La Tropical, El Llabiegu, La Xana, Boal II, La Pumarada.', icon: iconSidreria },

		// === GASCONA (Oviedo) ===
		{ lat: 43.3627, lng: -5.8478, name: 'Calle Gascona', info: 'La "Bulevar de la Sidra" de Oviedo. Concentración de sidrerías y tapeo.', icon: iconSidreria },

		// === BARES / COPAS ===
		{ lat: 43.5490, lng: -5.6628, name: 'Puerto Deportivo', info: 'Escondite, Bulevar, La Habana…', icon: iconBar },
		{ lat: 43.5448, lng: -5.6670, name: 'Zona de Fomento', info: 'Bodeguita del Medio, El Diario…', icon: iconBar },
		{ lat: 43.3618, lng: -5.8405, name: 'Zona El Rosal (Oviedo)', info: 'Zona clásica de copas.', icon: iconBar },
		{ lat: 43.3623, lng: -5.8420, name: 'Zona El Antiguo (Oviedo)', info: 'Ambiente nocturno y tapeo.', icon: iconBar },

		// === QUÉ VISITAR — Gijón ===
		{ lat: 43.5432, lng: -5.6520, name: 'Playa de San Lorenzo', info: 'Playa urbana en pleno centro de Gijón.', icon: iconVisit },
		{ lat: 43.5475, lng: -5.6640, name: 'Barrio de Cimadevilla', info: 'La parte más antigua, vestigios romanos y Termas de Campo Valdés.', icon: iconVisit },
		{ lat: 43.5497, lng: -5.6625, name: 'Cerro de Santa Catalina', info: 'Elogio del Horizonte de Chillida. Panorámica espectacular.', icon: iconVisit },
		{ lat: 43.5380, lng: -5.6453, name: 'Parque Isabel la Católica', info: 'Estanque de patos y cisnes, palomar y aviario.', icon: iconVisit },
		{ lat: 43.5362, lng: -5.6420, name: 'El Molinón', info: 'Estadio del Real Sporting de Gijón.', url: 'https://www.realsporting.com', icon: iconVisit },
		{ lat: 43.5260, lng: -5.6277, name: 'Universidad Laboral', info: '270.000 m², el edificio más grande de España (1946-1956).', url: 'https://www.laboralciudaddelacultura.com', icon: iconVisit },
		{ lat: 43.5629, lng: -5.7021, name: 'La Campa de Torres', info: 'Parque Arqueológico-Natural, restos del castro de Noega.', icon: iconVisit },
		{ lat: 43.5190, lng: -5.6173, name: 'Jardín Botánico Atlántico', info: 'Flora y vegetación atlántica. Tel: 985 18 51 30.', url: 'https://www.botanico.gijon.es', icon: iconVisit },

		// === QUÉ VISITAR — Oviedo ===
		{ lat: 43.3626, lng: -5.8432, name: 'La Catedral de Oviedo', info: 'Catedral gótica con Cámara Santa prerrománica.', url: 'https://catedraldeoviedo.com', icon: iconVisit },
		{ lat: 43.3621, lng: -5.8440, name: 'Barrio Antiguo (Oviedo)', info: 'Catedral, Palacio Arzobispal, Universidad Vieja.', icon: iconVisit },
		{ lat: 43.3740, lng: -5.8590, name: 'Monte Naranco', info: 'Santa María del Naranco (s. IX) y Cruz de la Victoria.', icon: iconVisit },

		// === QUÉ VISITAR — Pueblinos ===
		{ lat: 43.5632, lng: -6.1511, name: 'Cudillero', info: 'Pueblo pesquero encantador con verde y mar.', url: 'https://www.cudillero.es', icon: iconVisit },
		{ lat: 43.5157, lng: -5.2618, name: 'Lastres', info: '"San Martín del Sella" de Doctor Mateo.', icon: iconVisit },
		{ lat: 43.4613, lng: -5.0585, name: 'Ribadesella', info: 'Descenso internacional en piraguas del Sella.', url: 'https://www.ribadesella.es', icon: iconVisit },
		{ lat: 43.6138, lng: -5.7911, name: 'Luanco', info: 'Principal zona de veraneo de Asturias.', icon: iconVisit },
		{ lat: 43.5888, lng: -5.7602, name: 'Candás', info: 'Miradores, playas, puerto pesquero. Festival de la Sardina.', icon: iconVisit },
		{ lat: 43.4210, lng: -4.7557, name: 'Llanes', info: 'Cubos de la Memoria de Ibarrola. Playas preciosas.', url: 'https://www.llanes.es', icon: iconVisit },

		// === HOTELES ===
		{ lat: 43.5414, lng: -5.6596, name: 'Hotel Hernán Cortés', info: 'Fernández Vallín 5 · Tel: 985 346 000<br>Centro, 10 min de playa.', url: 'https://hotelhernancortes.es', icon: iconHotel },
		{ lat: 43.5470, lng: -5.6368, name: 'Hotel Begoña Park', info: 'Ctra. Providencia 566 · Tel: 985 133 909<br>Cerca del Rinconín.', url: 'https://hotelesbegona.com', icon: iconHotel },
		{ lat: 43.5385, lng: -5.6422, name: 'Hotel ABBA', info: 'Doctor Fleming 37<br>Junto a playa y Parque Isabel la Católica.', url: 'https://abbagijonhotel.com', icon: iconHotel },
		{ lat: 43.5379, lng: -5.6445, name: 'Parador Molino Viejo', info: 'Parque Isabel la Católica · Tel: 985 370 511<br>Antiguo molino, fabada estrella.', url: 'https://parador.es', icon: iconHotel },
		{ lat: 43.5395, lng: -5.6485, name: 'Hotel TRYP Rey Pelayo', info: 'V. Torcuato F. Miranda 26 · Tel: 985 199 800<br>Cerca de playa y Molinón.', icon: iconHotel },
		{ lat: 43.5380, lng: -5.6635, name: 'Hotel AC Gijón', info: 'Avda. de Oviedo 15 · Tel: 985 990 500<br>Moderno, zona residencial.', url: 'https://ac-hotels.com', icon: iconHotel },
		{ lat: 43.5445, lng: -5.6600, name: 'Hotel Blue Santa Rosa', info: 'Santa Rosa 4 · Tel: 985 091 919<br>Centro peatonal, 50m de playa.', url: 'https://bluehoteles.es', icon: iconHotel },
		{ lat: 43.5460, lng: -5.6610, name: 'Hotel Blue Marqués', info: 'Marqués de San Esteban 11 · Tel: 985 090 929<br>Edificio clásico junto al Puerto.', url: 'https://bluehoteles.es', icon: iconHotel },
		{ lat: 43.5408, lng: -5.6570, name: 'Hotel Begoña Centro', info: 'Avda. de la Costa 44 · Tel: 985 147 211<br>Centro, zona comercial.', url: 'https://hotelesbegona.com', icon: iconHotel },
		{ lat: 43.5430, lng: -5.6610, name: 'Hotel Miramar', info: 'C/ Santa Lucía 9 · Tel: 985 351 008<br>Edificio de 1926, junto a playa y puerto.', icon: iconHotel },
		{ lat: 43.5440, lng: -5.6550, name: 'Hotel Arena', info: 'Dr. Aquilino Hurlé 31 · Tel: 985 339 700<br>100m de playa San Lorenzo.', url: 'https://hotelarena.es', icon: iconHotel },
		{ lat: 43.5350, lng: -5.6560, name: 'Hotel Villa de Gijón', info: 'C/ San Juan de Vallés 3 · Tel: 985 141 824', url: 'https://hotelvilladegijon.com', icon: iconHotel },
		{ lat: 43.5425, lng: -5.6590, name: 'Hotel León', info: 'Avda. de la Costa 45 · Tel: 985 37 01 11', url: 'https://hotel-leon.com', icon: iconHotel },
		{ lat: 43.5438, lng: -5.6635, name: 'Apartamentos San Esteban', info: 'Marqués de San Esteban 11 · Tel: 985 09 09 29<br>Estudios y apartamentos.', url: 'https://bluehoteles.es', icon: iconHotel },
		{ lat: 43.5200, lng: -5.6120, name: 'Camping Deva', info: 'Camín de la Pasadiella 85 · Tel: 985 13 38 48<br>Bungalows, cabañas y chalets.', icon: iconHotel },
	];

	for (var i = 0; i < places.length; i++) {
		var p = places[i];
		var html = '<strong>' + p.name + '</strong><br>' + p.info;
		if (p.url) {
			html += '<br><a href="' + p.url + '" target="_blank" rel="noopener noreferrer" style="color:#1a6b3c;font-weight:600;font-size:0.85rem;">Visitar web &rarr;</a>';
		}
		L.marker([p.lat, p.lng], { icon: p.icon })
			.bindPopup(html)
			.addTo(map);
	}
});
</script>
