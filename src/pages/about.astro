---
import BaseLayout from '../layouts/BaseLayout.astro';

const skills = ["HTML", "CSS", "JavaScript", "React", "Astro", "Redacción de documentos"];
---

<BaseLayout pageTitle="Sobre mí">
  <h1>Sobre mí</h1>
  <p>¡Hola! Soy Manrique Garcia. Este es mi sitio personal donde comparto lo que voy aprendiendo.</p>

  <p>Estoy trabajando con Astro para construir este sitio. Se irá actualizando a medida que vaya avanzando, ¡así que no dejes de visitarlo!</p>

  <h2>Mis habilidades</h2>
  <ul>
    {skills.map((skill) => <li>{skill}</li>)}
  </ul>
</BaseLayout>
