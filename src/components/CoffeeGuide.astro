---
const coffees = [
  {
    name: 'Café de desayuno',
    subtitle: 'Tazón grande',
    desc: 'No existe esta medida en otros lugares',
    cupWidth: 100,
    cupHeight: 80,
    handleSize: 22,
    coffeePercent: 30,
    milkPercent: 70,
    isBowl: true,
  },
  {
    name: 'Café mediano',
    subtitle: 'Café con leche normal',
    desc: 'Lo que en el resto de España es un café con leche',
    cupWidth: 78,
    cupHeight: 70,
    handleSize: 18,
    coffeePercent: 45,
    milkPercent: 55,
    isBowl: false,
  },
  {
    name: 'Café con leche',
    subtitle: 'Tamaño cortado',
    desc: 'Ojo: aquí tiene la medida de un cortado',
    cupWidth: 62,
    cupHeight: 56,
    handleSize: 15,
    coffeePercent: 55,
    milkPercent: 45,
    isBowl: false,
  },
  {
    name: 'Cortado',
    subtitle: 'Café solo + gota de leche',
    desc: 'Café solo con una mancha de leche',
    cupWidth: 52,
    cupHeight: 46,
    handleSize: 12,
    coffeePercent: 85,
    milkPercent: 15,
    isBowl: false,
  },
];
---

<div class="coffee-guide">
  {coffees.map((c) => {
    const svgW = c.cupWidth + c.handleSize + 20;
    const svgH = c.cupHeight + 50;
    const cx = 10;
    const cy = 10;
    const innerPad = 4;
    const innerW = c.cupWidth - innerPad * 2;
    const innerH = c.cupHeight - innerPad - 6;
    const coffeeH = innerH * (c.coffeePercent / 100);
    const milkH = innerH * (c.milkPercent / 100);
    const taperX = c.isBowl ? 6 : 3;
    const taperBottom = c.isBowl ? 12 : 4;

    return (
      <div class="coffee-item">
        <svg
          viewBox={`0 0 ${svgW} ${svgH}`}
          width={svgW}
          height={svgH}
          xmlns="http://www.w3.org/2000/svg"
          aria-label={c.name}
          role="img"
        >
          {/* Saucer */}
          <ellipse
            cx={cx + c.cupWidth / 2}
            cy={cy + c.cupHeight - 2}
            rx={c.cupWidth / 2 + 8}
            ry={6}
            fill="#d4d0c8"
          />

          {/* Cup body */}
          <path
            d={`M ${cx + taperX} ${cy}
                L ${cx} ${cy + c.cupHeight - taperBottom}
                Q ${cx} ${cy + c.cupHeight} ${cx + taperBottom} ${cy + c.cupHeight}
                L ${cx + c.cupWidth - taperBottom} ${cy + c.cupHeight}
                Q ${cx + c.cupWidth} ${cy + c.cupHeight} ${cx + c.cupWidth} ${cy + c.cupHeight - taperBottom}
                L ${cx + c.cupWidth - taperX} ${cy}
                Z`}
            fill="#f5f0e8"
            stroke="#c9c4ba"
            stroke-width="1.5"
          />

          {/* Milk layer (bottom = most of cup) */}
          <clipPath id={`clip-${c.name.replace(/\s/g, '')}`}>
            <path
              d={`M ${cx + taperX + 1} ${cy + 3}
                  L ${cx + 1} ${cy + c.cupHeight - taperBottom}
                  Q ${cx + 1} ${cy + c.cupHeight - 1} ${cx + taperBottom + 1} ${cy + c.cupHeight - 1}
                  L ${cx + c.cupWidth - taperBottom - 1} ${cy + c.cupHeight - 1}
                  Q ${cx + c.cupWidth - 1} ${cy + c.cupHeight - 1} ${cx + c.cupWidth - 1} ${cy + c.cupHeight - taperBottom}
                  L ${cx + c.cupWidth - taperX - 1} ${cy + 3}
                  Z`}
            />
          </clipPath>

          <g clip-path={`url(#clip-${c.name.replace(/\s/g, '')})`}>
            {/* Milk fill */}
            <rect
              x={cx}
              y={cy + 3}
              width={c.cupWidth}
              height={c.cupHeight}
              fill="#f5e6d0"
            />
            {/* Coffee fill */}
            <rect
              x={cx}
              y={cy + 3 + milkH}
              width={c.cupWidth}
              height={coffeeH}
              fill="#5c3d2e"
            />
          </g>

          {/* Foam line */}
          <line
            x1={cx + taperX + 3}
            y1={cy + 5}
            x2={cx + c.cupWidth - taperX - 3}
            y2={cy + 5}
            stroke="#e8dcc8"
            stroke-width="2"
            stroke-linecap="round"
          />

          {/* Handle */}
          <path
            d={`M ${cx + c.cupWidth - 1} ${cy + c.cupHeight * 0.2}
                C ${cx + c.cupWidth + c.handleSize} ${cy + c.cupHeight * 0.2}
                  ${cx + c.cupWidth + c.handleSize} ${cy + c.cupHeight * 0.7}
                  ${cx + c.cupWidth - 1} ${cy + c.cupHeight * 0.7}`}
            fill="none"
            stroke="#c9c4ba"
            stroke-width="3"
            stroke-linecap="round"
          />

          {/* Steam */}
          <path
            d={`M ${cx + c.cupWidth * 0.35} ${cy - 4}
                Q ${cx + c.cupWidth * 0.35 - 4} ${cy - 14} ${cx + c.cupWidth * 0.35} ${cy - 22}`}
            fill="none"
            stroke="#c9c4ba"
            stroke-width="1.2"
            stroke-linecap="round"
            opacity="0.5"
          />
          <path
            d={`M ${cx + c.cupWidth * 0.55} ${cy - 6}
                Q ${cx + c.cupWidth * 0.55 + 4} ${cy - 16} ${cx + c.cupWidth * 0.55} ${cy - 26}`}
            fill="none"
            stroke="#c9c4ba"
            stroke-width="1.2"
            stroke-linecap="round"
            opacity="0.4"
          />
        </svg>

        <h3 class="coffee-name">{c.name}</h3>
        <p class="coffee-subtitle">{c.subtitle}</p>
        <p class="coffee-desc">{c.desc}</p>

        <div class="coffee-legend">
          <span class="legend-swatch coffee-swatch"></span> Café
          <span class="legend-swatch milk-swatch"></span> Leche
        </div>
      </div>
    );
  })}
</div>

<style>
  .coffee-guide {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
    align-items: end;
  }

  .coffee-item {
    text-align: center;
    background: #fff;
    border: 1px solid #e8e4de;
    border-radius: 12px;
    padding: 1.5rem 1rem 1.25rem;
    transition: box-shadow 0.2s;
  }

  .coffee-item:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
  }

  .coffee-item svg {
    display: block;
    margin: 0 auto 0.75rem;
  }

  .coffee-name {
    font-family: 'DM Serif Display', Georgia, serif;
    font-weight: 400;
    font-size: 1.05rem;
    margin: 0 0 0.15rem;
    color: #2c2c2c;
  }

  .coffee-subtitle {
    font-size: 0.82rem;
    color: #1a6b3c;
    font-weight: 600;
    margin: 0 0 0.35rem;
  }

  .coffee-desc {
    font-size: 0.78rem;
    color: #6b6b6b;
    margin: 0 0 0.6rem;
    line-height: 1.4;
  }

  .coffee-legend {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    color: #6b6b6b;
  }

  .legend-swatch {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 2px;
  }

  .coffee-swatch { background: #5c3d2e; }
  .milk-swatch { background: #f5e6d0; margin-left: 0.4rem; }
</style>
