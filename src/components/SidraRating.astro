---
interface Props {
  rating: 3 | 4 | 5;
}

const { rating } = Astro.props;
const labels = { 3: 'Buena', 4: 'Muy buena', 5: 'Excelente' } as const;
const max = 5;
---

<div class="sidra-rating" title={`${labels[rating]} (${rating} de ${max})`}>
  {Array.from({ length: max }).map((_, i) => (
    <svg
      class:list={['sidra-bottle', { active: i < rating }]}
      viewBox="0 0 24 48"
      width="18"
      height="36"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      {/* Tapón */}
      <rect x="9" y="0" width="6" height="4" rx="1" />
      {/* Cuello */}
      <rect x="10" y="4" width="4" height="8" rx="1" />
      {/* Hombro */}
      <path d="M10 12 Q10 16 6 18 L6 18 L18 18 Q14 16 14 12 Z" />
      {/* Cuerpo */}
      <rect x="6" y="18" width="12" height="24" rx="2" />
      {/* Etiqueta */}
      <rect x="8" y="24" width="8" height="10" rx="1" class="label" />
      {/* Base */}
      <rect x="5" y="42" width="14" height="3" rx="1.5" />
    </svg>
  ))}
  <span class="sidra-label">{labels[rating]}</span>
</div>

<style>
  .sidra-rating {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    margin: 0.5rem 0;
  }

  .sidra-bottle {
    fill: #d4d0c8;
    transition: fill 0.2s;
  }

  .sidra-bottle.active {
    fill: #1a6b3c;
  }

  .sidra-bottle .label {
    fill: #f5f0e8;
    opacity: 0.5;
  }

  .sidra-bottle.active .label {
    fill: #f5f0e8;
    opacity: 0.8;
  }

  .sidra-label {
    font-size: 0.78rem;
    color: #6b6b6b;
    margin-left: 0.4rem;
    font-weight: 500;
  }
</style>
