---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Guía para descubrir Asturias: restaurantes, sidrerías, hoteles y lugares que visitar' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Guía de Asturias</title>
  </head>
  <body>
    <header>
      <div class="container">
        <a href="/" class="site-title">Guía de Asturias</a>
        <nav>
          <a href="/" class={currentPath === '/' ? 'active' : ''}>Inicio</a>
          <a href="/restaurantes/" class={currentPath.startsWith('/restaurantes') ? 'active' : ''}>Restaurantes</a>
          <a href="/bares/" class={currentPath.startsWith('/bares') ? 'active' : ''}>Bares y Cafés</a>
          <a href="/visitar/" class={currentPath.startsWith('/visitar') ? 'active' : ''}>Qué visitar</a>
          <a href="/hoteles/" class={currentPath.startsWith('/hoteles') ? 'active' : ''}>Hoteles</a>
          <a href="/diccionario/" class={currentPath.startsWith('/diccionario') ? 'active' : ''}>Diccionario</a>
        </nav>
      </div>
    </header>
    <slot />
    <footer>
      <div class="container">
        &copy; {new Date().getFullYear()} manriquegarcia.com &mdash; Guía de Asturias
      </div>
    </footer>
  </body>
</html>
