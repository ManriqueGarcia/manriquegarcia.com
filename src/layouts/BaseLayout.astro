---
import '../styles/global.css';

interface Props {
  pageTitle: string;
}

const { pageTitle } = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle} | Manrique Garcia</title>
  </head>
  <body>
    <nav>
      <a href="/" class={currentPath === '/' ? 'active' : ''}>Inicio</a>
      <a href="/blog/" class={currentPath.startsWith('/blog') || currentPath.startsWith('/posts') ? 'active' : ''}>Blog</a>
      <a href="/about/" class={currentPath === '/about/' ? 'active' : ''}>Sobre mí</a>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      &copy; {new Date().getFullYear()} Manrique Garcia
    </footer>
  </body>
</html>
