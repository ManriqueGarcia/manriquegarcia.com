---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
---

<BaseLayout pageTitle={frontmatter.title}>
  <article>
    <h1>{frontmatter.title}</h1>
    <div class="post-meta">
      {frontmatter.pubDate && <span>{new Date(frontmatter.pubDate).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</span>}
      {frontmatter.author && <span> · {frontmatter.author}</span>}
    </div>
    {frontmatter.tags && (
      <div style="margin-bottom: 1.5rem;">
        {frontmatter.tags.map((tag: string) => <span class="tag">{tag}</span>)}
      </div>
    )}
    <slot />
  </article>
</BaseLayout>
